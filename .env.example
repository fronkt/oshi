# ─── Oshi env (example) ───────────────────────────────────────────────────────
# Copy to `.env` (gitignored). Two tiers, do not mix them up.

# CLIENT-SAFE — inlined into the app bundle by Expo. MUST be non-secret.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# ─── SERVER SECRETS — set via `supabase secrets set`, NEVER in the app bundle ──
#   Do NOT prefix these with EXPO_PUBLIC_ (that would ship them to the device).
#
# AniList OAuth app (anilist.co/settings/developer), authorization-code grant:
# ANILIST_CLIENT_ID=
# ANILIST_CLIENT_SECRET=
# ANILIST_REDIRECT_URI=oshi://auth/callback
#
# AES-GCM key (32 bytes, base64) — edge fns encrypt AniList tokens at rest with this:
# TOKEN_ENC_KEY=
#
# Supabase service role (server-only; bypasses RLS):
# SUPABASE_SERVICE_ROLE_KEY=
